LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
STORAGE_DIR=backend/storage
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
AUDIO_STORAGE_DIR=backend/storage/audio

# YTDLP_COOKIES_FILE 用于指定 cookies.txt 路径，例如 backend/storage/cookies/youtube_cookies.txt
YTDLP_COOKIES_FILE=
# YTDLP_COOKIES_FROM_BROWSER 用于从浏览器读取 cookie，例如 edge/chrome，但不推荐作为主方案
YTDLP_COOKIES_FROM_BROWSER=
# YTDLP_PROXY 用于给 yt-dlp 配置代理，例如 http://127.0.0.1:7890
YTDLP_PROXY=
YTDLP_USER_AGENT=
